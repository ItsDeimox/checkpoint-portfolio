{
  "name": "checkpoint-portfolio",
  "version": "0.1.0",
  "description": "Editor desktop local para portfolios publicados pelo GitHub Pages.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "check": "node --check main.js && node --check preload.js && node --check editor.js && node --check site.js",
    "dist": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "dev.checkpoint.portfolio",
    "productName": "Checkpoint Portfolio",
    "files": [
      "main.js",
      "preload.js",
      "editor.html",
      "editor.js",
      "styles.css",
      "index.html",
      "site.js",
      "content.json"
    ],
    "win": { "target": "nsis" },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
